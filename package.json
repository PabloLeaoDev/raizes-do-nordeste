{
  "name": "raizes-nordeste-api",
  "version": "1.0.0",
  "scripts": {
    "dev": "tsx watch src/server.ts",
    "build": "tsc",
    "start": "node dist/server.js",
    "test": "jest",
    "services:up": "docker-compose up -d",
    "services:stop": "docker-compose stop",
    "services:down": "docker-compose down",
    "migrate:up": "npm run build && node-pg-migrate -m ./dist/infra/db/migrations up",
    "migrate:down": "npm run build && node-pg-migrate -m ./dist/infra/db/migrations down",
    "migrate:create": "node-pg-migrate -j ts create"
  },
  "dependencies": {
    "@fastify/swagger": "^9.7.0",
    "@fastify/swagger-ui": "^5.2.6",
    "@types/async-retry": "^1.4.9",
    "async-retry": "^1.3.3",
    "bcrypt": "^5",
    "dotenv": "^16",
    "fastify": "^5.8.5",
    "fastify-type-provider-zod": "^6.1.0",
    "jsonwebtoken": "^9",
    "node-pg-migrate": "^8.0.4",
    "pg": "^8",
    "zod": "^4.4.1"
  },
  "devDependencies": {
    "@types/bcrypt": "^6.0.0",
    "@types/dotenv": "^6.1.1",
    "@types/jest": "^29",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/node": "^20",
    "@types/pg": "^8.20.0",
    "jest": "^29",
    "ts-jest": "^29",
    "ts-node": "^10.9.2",
    "tsx": "^4",
    "typescript": "^5"
  }
}
