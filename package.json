{
  "name": "raizes-nordeste-api",
  "version": "1.0.0",
  "scripts": {
    "build": "tsc && tsc-alias",
    "services:up": "docker-compose up -d",
    "services:stop": "docker-compose stop",
    "services:down": "docker-compose down",
    "services:wait:docker": "node dist/infra/scripts/wait-for-docker.js",
    "services:wait:database": "node dist/infra/scripts/wait-for-postgres.js",
    "migrate:up": "node-pg-migrate -m dist/infra/db/migrations up",
    "migrate:down": "node-pg-migrate -m dist/infra/db/migrations down",
    "migrate:create": "node-pg-migrate -j ts create",
    "seed": "node dist/infra/db/seed",
    "bootstrap": "npm run services:up && npm run services:wait:docker && npm run services:wait:database && npm run migrate:up && npm run seed",
    "app:start": "node dist/server.js",
    "start": "node dist/infra/scripts/exit-zero-on-sigint.js \"npm run bootstrap && npm run app:start\"",
    "dev": "npm run bootstrap && tsx watch src/server.ts",
    "prestart": "npm run build",
    "poststart": "npm run services:down",
    "test": "jest",
    "lint:prettier:check": "prettier --check .",
    "lint:prettier:fix": "prettier --write .",
    "postservices:down": "echo \"You can't stop me!\""
  },
  "dependencies": {
    "@fastify/swagger": "9.7.0",
    "@fastify/swagger-ui": "5.2.6",
    "async-retry": "1.3.3",
    "bcrypt": "5",
    "dotenv": "16",
    "fastify": "5.8.5",
    "fastify-type-provider-zod": "6.1.0",
    "jsonwebtoken": "9",
    "node-pg-migrate": "8.0.4",
    "pg": "8",
    "zod": "4.4.1"
  },
  "devDependencies": {
    "@types/async-retry": "1.4.9",
    "@types/bcrypt": "6.0.0",
    "@types/dotenv": "6.1.1",
    "@types/jest": "29",
    "@types/jsonwebtoken": "9.0.10",
    "@types/node": "20",
    "@types/pg": "8.20.0",
    "@types/supertest": "^7.2.0",
    "@types/uuid": "^10.0.0",
    "jest": "29",
    "jest-openapi": "0.14.2",
    "prettier": "3.8.4",
    "supertest": "^7.2.2",
    "ts-jest": "29",
    "ts-node": "10.9.2",
    "tsc-alias": "^1.8.17",
    "tsx": "4",
    "typescript": "5",
    "uuid": "^14.0.1"
  }
}
