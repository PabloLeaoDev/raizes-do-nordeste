{
  "openapi": "3.0.3",
  "info": {
    "title": "Raízes do Nordeste API",
    "description": "API para a rede de lanchonetes Raízes do Nordeste",
    "version": "1.0.0"
  },
  "servers": [
    {
      "url": "http://localhost:3000",
      "description": "Servidor local de desenvolvimento"
    }
  ],
  "components": {
    "securitySchemes": {
      "bearerAuth": {
        "type": "http",
        "scheme": "bearer",
        "bearerFormat": "JWT"
      }
    },
    "schemas": {
      "LoginBody": {
        "type": "object",
        "required": [
          "email",
          "senha"
        ],
        "properties": {
          "email": {
            "type": "string",
            "format": "email"
          },
          "senha": {
            "type": "string",
            "minLength": 6
          }
        }
      },
      "SignupBody": {
        "type": "object",
        "required": [
          "nome",
          "email",
          "senha"
        ],
        "properties": {
          "nome": {
            "type": "string",
            "minLength": 3
          },
          "email": {
            "type": "string",
            "format": "email"
          },
          "senha": {
            "type": "string",
            "minLength": 6
          },
          "perfil": {
            "type": "string",
            "enum": [
              "ADMIN",
              "GERENTE",
              "ATENDENTE",
              "CLIENTE"
            ],
            "default": "CLIENTE"
          }
        }
      },
      "LoginResponse": {
        "type": "object",
        "properties": {
          "token": {
            "type": "string",
            "description": "Token JWT de acesso"
          }
        }
      },
      "User": {
        "type": "object",
        "properties": {
          "id": {
            "type": "string",
            "format": "uuid"
          },
          "nome": {
            "type": "string"
          },
          "email": {
            "type": "string",
            "format": "email"
          },
          "perfil": {
            "type": "string",
            "enum": [
              "ADMIN",
              "GERENTE",
              "ATENDENTE",
              "CLIENTE"
            ]
          },
          "createdAt": {
            "type": "string",
            "format": "date-time"
          },
          "updatedAt": {
            "type": "string",
            "format": "date-time"
          }
        }
      },
      "Product": {
        "type": "object",
        "properties": {
          "id": {
            "type": "string",
            "format": "uuid"
          },
          "nome": {
            "type": "string",
            "minLength": 3
          },
          "descricao": {
            "type": "string"
          },
          "preco": {
            "type": "number",
            "exclusiveMinimum": false
          },
          "estoque_total": {
            "type": "integer",
            "minimum": 0,
            "default": 0
          },
          "createdAt": {
            "type": "string",
            "format": "date-time"
          },
          "updatedAt": {
            "type": "string",
            "format": "date-time"
          }
        }
      },
      "CreateProductBody": {
        "type": "object",
        "required": [
          "nome",
          "preco"
        ],
        "properties": {
          "nome": {
            "type": "string",
            "minLength": 3
          },
          "descricao": {
            "type": "string"
          },
          "preco": {
            "type": "number",
            "exclusiveMinimum": false
          },
          "estoque_total": {
            "type": "integer",
            "minimum": 0,
            "default": 0
          }
        }
      },
      "UpdateProductBody": {
        "type": "object",
        "properties": {
          "nome": {
            "type": "string",
            "minLength": 3
          },
          "descricao": {
            "type": "string"
          },
          "preco": {
            "type": "number",
            "exclusiveMinimum": false
          },
          "estoque_total": {
            "type": "integer",
            "minimum": 0
          }
        }
      },
      "OrderItem": {
        "type": "object",
        "required": [
          "produto_id",
          "quantidade"
        ],
        "properties": {
          "produto_id": {
            "type": "string",
            "format": "uuid"
          },
          "quantidade": {
            "type": "integer",
            "exclusiveMinimum": false
          }
        }
      },
      "CreateOrderBody": {
        "type": "object",
        "required": [
          "unidade_id",
          "canal",
          "itens"
        ],
        "properties": {
          "unidade_id": {
            "type": "string",
            "format": "uuid"
          },
          "canal": {
            "type": "string",
            "enum": [
              "APP",
              "TOTEM",
              "WEB"
            ]
          },
          "itens": {
            "type": "array",
            "minItems": 1,
            "items": {
              "$ref": "#/components/schemas/OrderItem"
            }
          }
        }
      },
      "Order": {
        "type": "object",
        "properties": {
          "id": {
            "type": "string",
            "format": "uuid"
          },
          "unidade_id": {
            "type": "string",
            "format": "uuid"
          },
          "canal": {
            "type": "string",
            "enum": [
              "APP",
              "TOTEM",
              "WEB"
            ]
          },
          "status": {
            "type": "string",
            "enum": [
              "AGUARDANDO_PAGAMENTO",
              "RECEBIDO",
              "EM_PREPARACAO",
              "PRONTO",
              "FINALIZADO",
              "CANCELADO"
            ]
          },
          "itens": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/OrderItem"
            }
          },
          "total": {
            "type": "number"
          },
          "createdAt": {
            "type": "string",
            "format": "date-time"
          },
          "updatedAt": {
            "type": "string",
            "format": "date-time"
          }
        }
      },
      "UpdateOrderStatusBody": {
        "type": "object",
        "required": [
          "status"
        ],
        "properties": {
          "status": {
            "type": "string",
            "enum": [
              "AGUARDANDO_PAGAMENTO",
              "RECEBIDO",
              "EM_PREPARACAO",
              "PRONTO",
              "FINALIZADO",
              "CANCELADO"
            ]
          }
        }
      },
      "Unit": {
        "type": "object",
        "properties": {
          "id": {
            "type": "string",
            "format": "uuid"
          },
          "nome": {
            "type": "string"
          },
          "endereco": {
            "type": "string"
          },
          "createdAt": {
            "type": "string",
            "format": "date-time"
          },
          "updatedAt": {
            "type": "string",
            "format": "date-time"
          }
        }
      },
      "CreateUnitBody": {
        "type": "object",
        "required": [
          "nome",
          "endereco"
        ],
        "properties": {
          "nome": {
            "type": "string"
          },
          "endereco": {
            "type": "string"
          }
        }
      },
      "UpdateUnitBody": {
        "type": "object",
        "properties": {
          "nome": {
            "type": "string"
          },
          "endereco": {
            "type": "string"
          }
        },
        "additionalProperties": false
      },
      "Error": {
        "type": "object",
        "properties": {
          "statusCode": {
            "type": "integer"
          },
          "error": {
            "type": "string"
          },
          "message": {
            "type": "string"
          }
        }
      }
    }
  },
  "paths": {
    "/auth/login": {
      "post": {
        "tags": [
          "Auth"
        ],
        "summary": "Autenticar usuário",
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/LoginBody"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Login realizado com sucesso",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/LoginResponse"
                }
              }
            }
          },
          "400": {
            "description": "Dados inválidos",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Error"
                }
              }
            }
          },
          "401": {
            "description": "Credenciais inválidas",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Error"
                }
              }
            }
          }
        }
      }
    },
    "/auth/signup": {
      "post": {
        "tags": [
          "Auth"
        ],
        "summary": "Criar novo usuário",
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/SignupBody"
              }
            }
          }
        },
        "responses": {
          "201": {
            "description": "Usuário criado com sucesso",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/User"
                }
              }
            }
          },
          "400": {
            "description": "Dados inválidos",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Error"
                }
              }
            }
          },
          "409": {
            "description": "E-mail já cadastrado",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Error"
                }
              }
            }
          }
        }
      }
    },
    "/produtos": {
      "get": {
        "tags": [
          "Products"
        ],
        "summary": "Listar todos os produtos",
        "security": [
          {
            "bearerAuth": []
          }
        ],
        "responses": {
          "200": {
            "description": "Lista de produtos",
            "content": {
              "application/json": {
                "schema": {
                  "type": "array",
                  "items": {
                    "$ref": "#/components/schemas/Product"
                  }
                }
              }
            }
          },
          "401": {
            "description": "Não autorizado"
          }
        }
      },
      "post": {
        "tags": [
          "Products"
        ],
        "summary": "Criar um novo produto",
        "security": [
          {
            "bearerAuth": []
          }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/CreateProductBody"
              }
            }
          }
        },
        "responses": {
          "201": {
            "description": "Produto criado com sucesso",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Product"
                }
              }
            }
          },
          "400": {
            "description": "Dados inválidos",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Error"
                }
              }
            }
          },
          "401": {
            "description": "Não autorizado"
          },
          "403": {
            "description": "Permissão insuficiente"
          }
        }
      },
      "put": {
        "tags": [
          "Products"
        ],
        "summary": "Atualizar um produto",
        "security": [
          {
            "bearerAuth": []
          }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/UpdateProductBody"
              }
            }
          }
        },
        "responses": {
          "201": {
            "description": "Produto atualizado com sucesso",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Product"
                }
              }
            }
          },
          "400": {
            "description": "Dados inválidos",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Error"
                }
              }
            }
          },
          "401": {
            "description": "Não autorizado"
          },
          "403": {
            "description": "Permissão insuficiente"
          }
        }
      },
      "delete": {
        "tags": [
          "Products"
        ],
        "summary": "Deletar um novo produto",
        "security": [
          {
            "bearerAuth": []
          }
        ],
        "responses": {
          "201": {
            "description": "Produto deletado com sucesso",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Product"
                }
              }
            }
          },
          "400": {
            "description": "Dados inválidos",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Error"
                }
              }
            }
          },
          "401": {
            "description": "Não autorizado"
          },
          "403": {
            "description": "Permissão insuficiente"
          }
        }
      }
    },
    "/pedidos": {
      "get": {
        "tags": [
          "Orders"
        ],
        "summary": "Listar pedidos (perfis: ADMIN, GERENTE, ATENDENTE)",
        "security": [
          {
            "bearerAuth": []
          }
        ],
        "responses": {
          "200": {
            "description": "Lista de pedidos",
            "content": {
              "application/json": {
                "schema": {
                  "type": "array",
                  "items": {
                    "$ref": "#/components/schemas/Order"
                  }
                }
              }
            }
          },
          "401": {
            "description": "Não autorizado"
          },
          "403": {
            "description": "Permissão insuficiente"
          }
        }
      },
      "post": {
        "tags": [
          "Orders"
        ],
        "summary": "Criar um novo pedido",
        "security": [
          {
            "bearerAuth": []
          }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/CreateOrderBody"
              }
            }
          }
        },
        "responses": {
          "201": {
            "description": "Pedido criado com sucesso",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Order"
                }
              }
            }
          },
          "400": {
            "description": "Dados inválidos",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Error"
                }
              }
            }
          },
          "401": {
            "description": "Não autorizado"
          }
        }
      }
    },
    "/pedidos/{id}/status": {
      "patch": {
        "tags": [
          "Orders"
        ],
        "summary": "Atualizar status de um pedido (perfis: ADMIN, GERENTE, ATENDENTE)",
        "security": [
          {
            "bearerAuth": []
          }
        ],
        "parameters": [
          {
            "name": "id",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string",
              "format": "uuid"
            }
          }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/UpdateOrderStatusBody"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Status atualizado",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Order"
                }
              }
            }
          },
          "400": {
            "description": "Dados inválidos",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Error"
                }
              }
            }
          },
          "401": {
            "description": "Não autorizado"
          },
          "403": {
            "description": "Permissão insuficiente"
          },
          "404": {
            "description": "Pedido não encontrado"
          }
        }
      }
    },
    "/unidades": {
      "get": {
        "tags": [
          "Units"
        ],
        "summary": "Listar unidades (perfis: ADMIN, GERENTE)",
        "security": [
          {
            "bearerAuth": []
          }
        ],
        "responses": {
          "200": {
            "description": "Lista de unidades",
            "content": {
              "application/json": {
                "schema": {
                  "type": "array",
                  "items": {
                    "$ref": "#/components/schemas/Unit"
                  }
                }
              }
            }
          },
          "401": {
            "description": "Não autorizado"
          },
          "403": {
            "description": "Permissão insuficiente"
          }
        }
      },
      "post": {
        "tags": [
          "Units"
        ],
        "summary": "Criar unidade (apenas ADMIN)",
        "security": [
          {
            "bearerAuth": []
          }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/CreateUnitBody"
              }
            }
          }
        },
        "responses": {
          "201": {
            "description": "Unidade criada",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Unit"
                }
              }
            }
          },
          "400": {
            "description": "Dados inválidos",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Error"
                }
              }
            }
          },
          "401": {
            "description": "Não autorizado"
          },
          "403": {
            "description": "Permissão insuficiente"
          }
        }
      }
    },
    "/unidades/{id}": {
      "get": {
        "tags": [
          "Units"
        ],
        "summary": "Buscar unidade por ID (perfis: ADMIN, GERENTE)",
        "security": [
          {
            "bearerAuth": []
          }
        ],
        "parameters": [
          {
            "name": "id",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string",
              "format": "uuid"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Dados da unidade",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Unit"
                }
              }
            }
          },
          "401": {
            "description": "Não autorizado"
          },
          "403": {
            "description": "Permissão insuficiente"
          },
          "404": {
            "description": "Unidade não encontrada"
          }
        }
      },
      "put": {
        "tags": [
          "Units"
        ],
        "summary": "Atualizar unidade (apenas ADMIN)",
        "security": [
          {
            "bearerAuth": []
          }
        ],
        "parameters": [
          {
            "name": "id",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string",
              "format": "uuid"
            }
          }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/UpdateUnitBody"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Unidade atualizada",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Unit"
                }
              }
            }
          },
          "400": {
            "description": "Dados inválidos",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Error"
                }
              }
            }
          },
          "401": {
            "description": "Não autorizado"
          },
          "403": {
            "description": "Permissão insuficiente"
          },
          "404": {
            "description": "Unidade não encontrada"
          }
        }
      },
      "delete": {
        "tags": [
          "Units"
        ],
        "summary": "Remover unidade (apenas ADMIN)",
        "security": [
          {
            "bearerAuth": []
          }
        ],
        "parameters": [
          {
            "name": "id",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string",
              "format": "uuid"
            }
          }
        ],
        "responses": {
          "204": {
            "description": "Unidade removida com sucesso"
          },
          "401": {
            "description": "Não autorizado"
          },
          "403": {
            "description": "Permissão insuficiente"
          },
          "404": {
            "description": "Unidade não encontrada"
          }
        }
      }
    }
  },
  "tags": [
    {
      "name": "Auth",
      "description": "Autenticação e registro de usuários"
    },
    {
      "name": "Products",
      "description": "Gerenciamento de produtos"
    },
    {
      "name": "Orders",
      "description": "Gerenciamento de pedidos"
    },
    {
      "name": "Units",
      "description": "Gerenciamento de unidades"
    }
  ]
}